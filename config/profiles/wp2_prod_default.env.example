# WP-2：生产/高噪机**示例**（更省 CPU、更可能丢非关键事件；需与容量规划一起调参）
# 与 agent.toml 中 [collection] max_event_queue_size、[preprocessing] sampling_rate_whitelist 联动
# 实际生产请以压测与漏报评估为准

# L2：未命中 TOML emit 规则时，对行为类进程事件抽样；KEEP_RATIO 默认来自 sampling_rate_whitelist，且 ≤0.10 被实现钳制
set EDR_PREPROCESS_L2_SPLIT=1
# set EDR_PREPROCESS_L2_KEEP_RATIO=0.03

# L3：总线占用超阈时丢「低价值」行为槽（高价值类型仍优先）
set EDR_PREPROCESS_L3_PRESSURE=1
# set EDR_PREPROCESS_L3_HIGH_PCT=80
# set EDR_PREPROCESS_L3_RECOVER_PCT=60
# set EDR_PREPROCESS_L3_DROP_PERMILLE=900

# 进程名门控：默认 1；调整 KEEP_UNKNOWN_PERMILLE 可改变「未在门控表中的进程名」被保留的千分比
set EDR_PREPROCESS_PROCNAME_GATE=1
# set EDR_PREPROCESS_PROCNAME_GATE_KEEP_UNKNOWN_PERMILLE=30

# 严格行为门控：仅压测/验证，一般生产保持不设置 1
# set EDR_PREPROCESS_STRICT_BEHAVIOR_GATE=0
