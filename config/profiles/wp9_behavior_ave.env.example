# WP-9：行为管线 / `on_behavior_alert` / 上送编码 — 与 agent.toml [ave]、预处理器同仓对表
# 用法：cmd 中 set VAR=value；Bash: export VAR=value

# ===== 平台行为告警帧 =====
# 平台行为告警帧建议与 ingest 一致（与 behavior_alert_emit 警告对表）
# set EDR_BEHAVIOR_ENCODING=protobuf

# ===== ONNX 推理频率控制 =====
# A3：ETW → AVE 喂入 1/N 分频（不作用于 TDH/总线）；
# ONNX 推理是最大 CPU 消耗点，生产环境建议 N>=4。
#   N=1  → 全量喂入（实验室/联调）
#   N=2  → 一半事件喂入（标准服务器）
#   N=4  → 四分之一喂入（推荐生产默认值）
#   N=8  → 八分之一喂入（高密度/VPS）
# set EDR_AVE_ETW_FEED_EVERY_N=4

# A3.2：异步喂入（队列+工作线程），与 TDH/总线解耦，默认关
# 开启后 ETW 回调不再阻塞在 AVE 入队上
# set EDR_AVE_ETW_ASYNC=1

# 完全关闭 ETW→AVE 映射（仅保留 TDH→总线，适合文件服务器等非交互场景）
# set EDR_AVE_ETW_FEED=0

# ===== 告警阈值 =====
# 高异常分门槛（与 ave_behavior_gates.h / 产品调参 一致时再用）
# set EDR_AVE_BEH_SCORE_HIGH=0.9

# 动态阈值控制：0 关闭，回退到固定步长（更少推理→更低CPU）
# set EDR_AVE_BEH_DYNAMIC_THRESHOLD=0

# ===== 推理步长（与 pipeline 内 EDR_AVE_BEH_INFER_MIN_EVENTS 注释互参） =====
# 显式指定每 N 条事件推理一次（传统模式；设置后动态阈值/立即触发均不生效）
# set EDR_AVE_BEH_INFER_MIN_EVENTS=8
