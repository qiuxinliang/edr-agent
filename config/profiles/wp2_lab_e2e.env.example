# WP-2：实验室 / E2E / 与 WP-1+真机 对照时推荐（易出数、减随机丢事件）
# 使用：在启动 edr_agent 的同一 shell 中 source（Linux）或逐条 set（Windows cmd）
# 勿将含密钥的副本提交到仓库

# 关闭 L2：未命中 emit 规则时不再做「抽掉 97%」那类限载
set EDR_PREPROCESS_L2_SPLIT=0

# 关闭 L3 高压：总线高水位时不再额外丢非高价值行为事件
set EDR_PREPROCESS_L3_PRESSURE=0

# 关闭进程名门控：减少对未知进程名的随机抽丢
set EDR_PREPROCESS_PROCNAME_GATE=0

# 可选：与 strict 门控联调/压测无关时保持不设置
# set EDR_PREPROCESS_STRICT_BEHAVIOR_GATE=0

# 可选：P0 直出真机 + 与平台一致时用（另见 EDR_P0_DIRECT_EMIT_E2E.md）
# set EDR_P0_DIRECT_EMIT=1
# set EDR_BEHAVIOR_ENCODING=protobuf
